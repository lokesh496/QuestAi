rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidGeneration(data) {
      return data.id is string &&
             data.userId is string &&
             data.topic is string &&
             data.topic.size() <= 200 &&
             data.type in ['coding', 'mcq'] &&
             data.questions is list &&
             data.timestamp is string;
    }

    match /generations/{genId} {
      // Users can only read their own generations
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Users can create their own generations
      allow create: if isSignedIn() && 
                      request.auth.uid == request.resource.data.userId &&
                      isValidGeneration(request.resource.data);
      
      // Generations are immutable after creation
      allow update, delete: if false;
    }
  }
}
